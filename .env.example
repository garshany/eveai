# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY=socks5h://127.0.0.1:10808
TELEGRAM_TIMEOUT_SECONDS=20

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
# Reasoning effort: low | medium | high (if supported by the backend)
OPENAI_REASONING_EFFORT=low
# Native codex proxy responses endpoint
# OPENAI_BASE_URL=http://localhost:8088/v1
# OPENAI_API_KEY=any-value
# OPENAI_API_MODE=native_responses

# EVE SSO
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:3000/auth/eve/callback
ESI_BASE_URL=https://esi.evetech.net/latest/
ESI_SPEC_URL=https://esi.evetech.net/latest/swagger.json
ESI_CATALOG_CACHE_PATH=./data/cache/esi-swagger.json
ESI_COMPATIBILITY_DATE=2026-03-15
ESI_MAX_PAGES=5
ESI_BACKOFF_MAX_SECONDS=10

# Server
PORT=3000
HOST=0.0.0.0

# Database
DB_PATH=./data/eve-agent.db
USER_PROFILE_PATH=./data/USER_{character_id}.md
USER_PROFILE_REFRESH_SECONDS=300
DEFAULT_MARKET_REGION_ID=10000002
DEFAULT_MARKET_REGION_NAME=The Forge

# Web search tool
WEB_SEARCH_TIMEOUT_MS=8000
WEB_SEARCH_MAX_RESULTS=5

# SDE
SDE_DATA_DIR=./data/sde

# Allowed Telegram user ID. Set `0` to disable the whitelist and allow any private chat.
ALLOWED_TELEGRAM_USER_ID=0

# Auto-compact (long memory)
COMPACT_MESSAGE_THRESHOLD=50
COMPACT_TOKEN_RATIO=0.6
COMPACT_TOKEN_BUDGET=8000
COMPACT_KEEP_LAST=10
COMPACT_MAX_INPUT_CHARS=20000
