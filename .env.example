# Bot platforms: fill in at least one token (both may run at once).

# Telegram
# Create a bot with @BotFather. Long polling is used; do not configure webhooks.
TELEGRAM_BOT_TOKEN=
# Optional proxy for Telegram API, for example socks5h://127.0.0.1:10808
TELEGRAM_PROXY=
TELEGRAM_TIMEOUT_SECONDS=20
# Optional allowlist. Set 0 to allow any private Telegram user.
ALLOWED_TELEGRAM_USER_ID=0
# Shared ingress controls (the historical TELEGRAM_ prefix also governs Discord).
TELEGRAM_REQUEST_WINDOW_MS=60000
TELEGRAM_MAX_REQUESTS_PER_WINDOW=6
TELEGRAM_MAX_ACTIVE_REQUESTS_GLOBAL=8

# Discord
# Create an application at https://discord.com/developers/applications,
# add a bot, and invite it to your server. No privileged intents are needed.
# The bot answers in DMs (напиши ему в личные сообщения).
DISCORD_BOT_TOKEN=
# Optional allowlist: a Discord user id (snowflake). Empty = allow any user.
ALLOWED_DISCORD_USER_ID=

# Responses provider. IDs map to fixed transports/endpoints; OPENAI_BASE_URL is ignored.
# Provider choices: openai | cheapvibecode
OPENAI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
# Model choices: gpt-5.6-sol | gpt-5.6-terra | gpt-5.6-luna (gpt-5.6 aliases Sol).
# stateless = rebuild context from SQLite on every turn (default/rollback).
# server = OpenAI-only previous_response_id continuation; requires store=true.
# CheapVibeCode uses one-shot WebSockets and requires stateless.
OPENAI_RESPONSE_STATE_MODE=stateless
# Opt in to OpenAI Dashboard Logs and API retrieval of stored Responses.
# Stored requests may include chat context and tool outputs. Keep false unless
# the operator accepts OpenAI's applicable data-retention policy.
OPENAI_STORE_RESPONSES=false
# Default-off hosted Programmatic Tool Calling for nine bounded public-read tools.
# Only true or false are valid. Enable only for an entitled model/project;
# false plus restart is the immediate no-migration rollback switch.
OPENAI_PROGRAMMATIC_TOOL_CALLING=false
# auto uses the local goal classifier; fixed values override it for normal chat turns.
# Reasoning effort: auto | none | low | medium | high | xhigh | max
OPENAI_REASONING_EFFORT=auto
# Reasoning mode: standard | pro. Pro is slower and can consume more tokens.
OPENAI_REASONING_MODE=standard
# Text verbosity: low | medium | high. Low fits chat-sized answers.
OPENAI_TEXT_VERBOSITY=low
# Increase deliberately for Pro/quality-first requests that may exceed 90 seconds.
OPENAI_RESPONSES_TIMEOUT_MS=90000
# Single-process provider backpressure for public multi-user traffic.
OPENAI_MAX_CONCURRENT_RESPONSES=8
OPENAI_MAX_QUEUED_RESPONSES=32
OPENAI_RESPONSE_QUEUE_TIMEOUT_MS=15000
# Bound leaf public-read fan-out across all users; writes/UI are globally serialized.
AGENT_MAX_CONCURRENT_READ_TOOLS=16
AGENT_MAX_QUEUED_TOOLS=64
AGENT_TOOL_QUEUE_TIMEOUT_MS=15000
# Default answer language for final user-facing responses. Examples: ru, русский, en, English.
OPENAI_RESPONSE_LANGUAGE=Russian
OPENAI_MAX_OUTPUT_TOKENS=0
OPENAI_COMPACT_THRESHOLD=0
# Local compaction budget, not a provider-advertised model limit.
OPENAI_MODEL_CONTEXT_WINDOW=200000

# EVE SSO
# Register an application at https://developers.eveonline.com/ and use the callback below for local dev.
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
# Required outside throwaway local testing. Generate with: openssl rand -base64 32
AUTH_SECRET_KEY=
EVE_CALLBACK_URL=http://localhost:3000/auth/eve/callback
SSO_REQUEST_TIMEOUT_MS=8000

# ESI
ESI_BASE_URL=https://esi.evetech.net/latest/
ESI_SPEC_URL=https://esi.evetech.net/latest/swagger.json
ESI_CATALOG_CACHE_PATH=./data/cache/esi-swagger.json
ESI_COMPATIBILITY_DATE=2026-03-15
# Replace contact= with your reachable operator contact before running a public instance.
ESI_USER_AGENT=EVEAI/3.3 (+https://github.com/example/eveai; contact=operator@example.com)
ESI_MAX_PAGES=5
ESI_BACKOFF_MAX_SECONDS=10
ESI_REQUEST_TIMEOUT_MS=8000
ESI_RETRY_MAX_ATTEMPTS=3

# Server (EVE SSO callback, optional browser chat, and health endpoint)
PORT=3000
HOST=127.0.0.1
WEB_BASE_URL=http://localhost:3000
# Explicit opt-in: enables same-origin React app and anonymous browser sessions.
WEB_CHAT_ENABLED=false
# Enable only behind a reverse proxy you control so Fastify can trust client IPs.
WEB_TRUST_PROXY=false
# Browser session lifetime, bounded to 1..8760 hours.
WEB_SESSION_TTL_HOURS=720
# Bound anonymous-session creation per client address before rows reach SQLite.
WEB_SESSION_CREATION_WINDOW_SECONDS=600
WEB_MAX_SESSION_CREATIONS_PER_WINDOW=30

# Database and local generated data
DB_PATH=./data/eve-agent.db
SDE_DATA_DIR=./data/sde
USER_PROFILE_PATH=./data/USER_{chat_id}_{character_id}.md
USER_PROFILE_REFRESH_SECONDS=300
DEFAULT_MARKET_REGION_ID=10000002
DEFAULT_MARKET_REGION_NAME="The Forge"

# Optional web search (https://tavily.com)
TAVILY_API_KEY=

# EVE-KILL
# Positive values only. Timeout/backoff are capped at 60000 ms; attempts at 5.
EVE_KILL_TIMEOUT_MS=8000
EVE_KILL_USER_AGENT=EVEAI/3.3 (+https://github.com/example/eveai; contact=operator@example.com)
EVE_KILL_RETRY_MAX_ATTEMPTS=3
EVE_KILL_BACKOFF_MAX_MS=10000

# EVE-Scout
EVE_SCOUT_BASE_URL=https://api.eve-scout.com/v2/public/
EVE_SCOUT_TIMEOUT_MS=8000
EVE_SCOUT_CACHE_TTL_SECONDS=300
EVE_SCOUT_USER_AGENT=EVEAI/3.3 (+https://github.com/example/eveai; contact=operator@example.com)
EVE_SCOUT_RETRY_MAX_ATTEMPTS=2
EVE_SCOUT_BACKOFF_MAX_MS=5000

# Prompt/history compaction
COMPACT_MAX_INPUT_CHARS=20000
