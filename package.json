{
  "name": "eve-agent",
  "version": "0.1.0",
  "description": "Single-user EVE Online agent with Telegram bot, native ESI tools, hosted tool_search, and local SDE",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/app.js",
    "dev": "tsx src/app.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run",
    "db:migrate": "tsx src/db/migrations.ts",
    "sde:load": "tsx src/eve/sde-loader.ts",
    "sde:download": "tsx src/eve/sde-downloader.ts",
    "setup": "npm run sde:download && npm run sde:load"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "grammy": "^1.35.0",
    "https-proxy-agent": "^8.0.0",
    "jose": "^6.2.1",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
