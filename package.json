{
  "name": "eve-agent",
  "version": "1.0.0",
  "description": "Multi-user EVE Online agent with Telegram, EVE SSO, native ESI tools, and local SDE",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/app.js",
    "dev": "npm run build:client && concurrently \"vite build --watch\" \"tsx src/app.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run && npm run lint",
    "db:migrate": "tsx src/db/migrations.ts",
    "db:diagnose-links": "tsx src/db/diagnose-links.ts",
    "sde:load": "tsx src/eve/sde-loader.ts",
    "sde:download": "tsx src/eve/sde-downloader.ts",
    "setup": "npm run sde:download && npm run sde:load",
    "smoke": "tsx src/smoke.ts"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.6",
    "@fontsource/space-grotesk": "^5.2.6",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^11.8.0",
    "croner": "^10.0.1",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "grammy": "^1.35.0",
    "https-proxy-agent": "^8.0.0",
    "jose": "^6.2.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socks-proxy-agent": "^8.0.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.1.5",
    "vitest": "^3.0.0"
  }
}
