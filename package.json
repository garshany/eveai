{
  "name": "eveonline-ai",
  "version": "2.2.0",
  "description": "Self-hosted Telegram and Discord AI assistant for EVE Online using the OpenAI Responses API, EVE SSO, ESI, and local SDE",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garshany/eveonline_ai.git"
  },
  "homepage": "https://github.com/garshany/eveonline_ai#readme",
  "bugs": {
    "url": "https://github.com/garshany/eveonline_ai/issues"
  },
  "keywords": [
    "eve-online",
    "telegram-bot",
    "openai",
    "responses-api",
    "esi",
    "sqlite",
    "sde"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run && npm run lint",
    "db:migrate": "tsx src/db/migrations.ts",
    "db:diagnose-links": "tsx src/db/diagnose-links.ts",
    "sde:load": "tsx src/eve/sde-loader.ts",
    "sde:download": "tsx src/eve/sde-downloader.ts",
    "setup": "npm run sde:download && npm run sde:load",
    "smoke": "tsx src/smoke.ts",
    "smoke:openai": "tsx scripts/openai-smoke.ts",
    "smoke:eve-tool": "tsx scripts/eve-tool-smoke.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "croner": "^10.0.1",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "grammy": "^1.35.0",
    "https-proxy-agent": "^9.1.0",
    "jose": "^6.2.1",
    "socks-proxy-agent": "^10.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
